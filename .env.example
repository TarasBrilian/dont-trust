# Copy to .env per app and fill in. Never commit real values.

# --- apps/attestor ---
# 32-byte BabyJubjub private key (hex). The custodian's signing key.
ATTESTOR_PRIVATE_KEY=

# --- apps/api ---
PORT=3001
# Stellar / Soroban
RPC_URL=https://soroban-testnet.stellar.org
NETWORK=testnet
VERIFIER_ID=
TOKEN_ID=
# ZK artifacts produced by packages/zk/build.sh
ZK_WASM_PATH=packages/zk/build/proof_of_backing_js/proof_of_backing.wasm
ZK_ZKEY_PATH=packages/zk/build/proof_of_backing_final.zkey

# --- apps/web (public, exposed to the browser) ---
NEXT_PUBLIC_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_VERIFIER_ID=
NEXT_PUBLIC_TOKEN_ID=
